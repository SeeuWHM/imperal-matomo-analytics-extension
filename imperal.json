{
  "manifest_schema_version": 3,
  "sdk_version": "5.0.1",
  "app_id": "analytics",
  "version": "4.0.6",
  "name": "Matomo Analytics",
  "description": "Traffic analytics dashboard: visits, trends, top pages, sources, devices, geo, audience insights and AI anomaly detection from your Matomo instance.",
  "icon": "icon.svg",
  "actions_explicit": true,
  "system": false,
  "capabilities": [
    "Traffic Overview",
    "Top Pages & Content",
    "Traffic Sources",
    "Audience Insights",
    "Real-time Visitors",
    "Campaign Analytics",
    "AI Daily Report",
    "Anomaly Detection"
  ],
  "tools": [
    {
      "name": "analytics",
      "description": "Traffic analytics powered by Matomo. Use for ANY question about: visits, pageviews, bounce rate, sessions, traffic sources, top pages, countries, devices, new vs returning visitors, UTM campaigns, social networks, real-time visitors, traffic trends, anomalies, daily reports, audience insights. Keywords: \u0442\u0440\u0430\u0444\u0438\u043a, \u043f\u043e\u0441\u0435\u0442\u0438\u0442\u0435\u043b\u0438, \u0432\u0438\u0437\u0438\u0442\u044b, \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u044b, \u0430\u043d\u0430\u043b\u0438\u0442\u0438\u043a\u0430 \u0441\u0430\u0439\u0442\u0430, \u043e\u0442\u043a\u0443\u0434\u0430 \u0442\u0440\u0430\u0444\u0438\u043a, \u0431\u0440\u0430\u0443\u0437\u0435\u0440\u044b, \u0441\u0442\u0440\u0430\u043d\u044b, \u0443\u0441\u0442\u0440\u043e\u0439\u0441\u0442\u0432\u0430, \u0430\u043d\u043e\u043c\u0430\u043b\u0438\u0438.",
      "scopes": [],
      "parameters": {
        "message": {
          "type": "string",
          "required": false
        },
        "kwargs": {
          "type": "string",
          "required": true
        }
      }
    },
    {
      "name": "skeleton_refresh_traffic_overview",
      "description": "Last 7 days traffic: visits, pageviews, bounce rate, avg session time, week-over-week change",
      "scopes": [],
      "parameters": {}
    },
    {
      "name": "skeleton_refresh_top_pages",
      "description": "Top 10 pages by visits this week with bounce rate and avg time on page",
      "scopes": [],
      "parameters": {}
    },
    {
      "name": "skeleton_refresh_realtime",
      "description": "Real-time visitor counts: last 30, 60, 180 minutes",
      "scopes": [],
      "parameters": {}
    },
    {
      "name": "skeleton_refresh_matomo_config",
      "description": "Matomo connection status, site URL, site ID, blog URL, UTM dimension ID",
      "scopes": [],
      "parameters": {}
    },
    {
      "name": "traffic",
      "description": "Get site traffic summary: visits, pageviews, bounce rate over a period.",
      "action_type": "read",
      "chain_callable": false,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "period": {
            "default": "day",
            "description": "Matomo period granularity",
            "enum": [
              "day",
              "week",
              "month",
              "year",
              "range"
            ],
            "title": "Period",
            "type": "string"
          },
          "date": {
            "default": "last7",
            "description": "Matomo date token. Common: today, yesterday, last7, last14, last30, last90, thisWeek, lastWeek, thisMonth, lastMonth. For period=range pass YYYY-MM-DD,YYYY-MM-DD.",
            "title": "Date",
            "type": "string"
          }
        },
        "title": "TrafficParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "scopes": [],
      "owner_chat_tool": "analytics"
    },
    {
      "name": "top_pages",
      "description": "Top pages by visits for a given period.",
      "action_type": "read",
      "chain_callable": false,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "properties": {
          "period": {
            "default": "month",
